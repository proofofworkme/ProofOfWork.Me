{
  "name": "proofofwork-me",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "check:work-market-v2": "node scripts/check-work-market-v2.mjs",
    "migrate:work-market-v2-cutover": "node scripts/migrate-work-market-v2-cutover.mjs",
    "dev": "vite --host 0.0.0.0",
    "dev:prod-api": "vite --host 0.0.0.0 --mode prod-api",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check:ui": "node scripts/check-ui-contract.mjs",
    "check:ui:browser": "playwright test --config playwright.ui.config.mjs",
    "check:hardening": "node scripts/check-hardening-contract.mjs",
    "check:api-truth": "node scripts/check-api-truth-contract.mjs",
    "check:electrum-client": "node scripts/check-electrum-client.mjs",
    "check:message-signatures": "node scripts/check-bitcoin-message-signatures.mjs",
    "check:live-data": "node scripts/check-live-data-contract.mjs",
    "check:index-recovery-behavior": "node scripts/check-index-recovery-behavior.mjs",
    "check:client-read-containment": "node scripts/check-client-read-containment.mjs",
    "check:worker-containment": "node scripts/check-worker-containment.mjs",
    "check:send-prep-regressions": "node scripts/check-send-prep-regressions.mjs",
    "check:credit-mint-regressions": "node scripts/check-credit-mint-regressions.mjs",
    "check:marketplace-regressions": "node scripts/check-marketplace-regressions.mjs",
    "check:marketplace-regressions:full": "MARKETPLACE_REGRESSION_MODE=full node scripts/check-marketplace-regressions.mjs",
    "check:mail-regressions": "node scripts/check-mail-regressions.mjs",
    "check:work-participant-regression": "node scripts/check-work-participant-regression.mjs",
    "check:work-precision": "node scripts/check-work-precision-contract.mjs",
    "check:bond-exact-arithmetic": "node scripts/check-bond-exact-arithmetic.mjs",
    "check:incb-range-replay-witness": "node scripts/check-incb-range-replay-witness.mjs",
    "db:schema": "node scripts/apply-proof-indexer-schema.mjs",
    "indexer:backfill": "node scripts/backfill-proof-indexer.mjs",
    "indexer:prepare-pwt-range-replay": "node scripts/backfill-proof-indexer.mjs --prepare-canonical-pwt-range-replay",
    "indexer:audit-work-atoms": "node scripts/backfill-proof-indexer.mjs --audit-work-atoms",
    "indexer:migrate-work-atoms": "node scripts/backfill-proof-indexer.mjs --migrate-work-atoms",
    "indexer:verify-work-atoms-post-bootstrap": "node scripts/backfill-proof-indexer.mjs --verify-work-atoms-post-bootstrap",
    "indexer:parity": "node scripts/check-proof-indexer-parity.mjs",
    "indexer:worker": "node scripts/run-proof-indexer-worker.mjs",
    "audit:ledger": "node scripts/audit-ledger-consistency.mjs",
    "audit:computer-events": "node scripts/audit-computer-events.mjs",
    "audit:ids": "node scripts/audit-id-registry.mjs",
    "deck:general": "node scripts/build-general-deck.mjs",
    "rank:powids": "node scripts/rank-powid-transactions.mjs",
    "proof-api": "node server/proof-api.mjs"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "bitcoinjs-lib": "^7.0.1",
    "buffer": "^6.0.3",
    "lucide-react": "^1.14.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^5.7.2",
    "vite": "^8.1.4"
  }
